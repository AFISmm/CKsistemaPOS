# Store Server — variables de entorno (Fase 1)
# Copiar a .env y ajustar. Nunca commitear .env con credenciales reales.

# Cadena de conexion a PostgreSQL local del Store Server (fuente de verdad de la tienda).
DATABASE_URL="postgresql://ckpos:ckpos@localhost:5432/ckpos_store?schema=public"

# Puerto HTTP/WS del Store Server (LAN de la tienda).
PORT=3001

# Ubicacion piloto por defecto (Miami, FL) usada cuando el cliente no envia ubicacionId.
UBICACION_PILOTO_ID="ubic-miami-fl"

# Rondas de costo de bcrypt para pinHash (S-10). 10-12 recomendado.
BCRYPT_SALT_ROUNDS=10

# Dayparts para GET /api/v1/reportes/dia (F2-T3, HU-REP-01 CA3, S-04). JSON de
# DefinicionDaypart[] = {nombre, horaInicio, horaFin}[] (horas locales, 0-23,
# deben cubrir 0-24 sin huecos). Si falta, no parsea, o es invalido, se usa el
# default documentado en src/reportes/dayparts.ts (Madrugada/Desayuno/Almuerzo/
# Tarde/Cena) — pendiente de validacion final por operaciones (S-04).
# REPORTES_DAYPARTS_JSON=[{"nombre":"Desayuno","horaInicio":6,"horaFin":11},{"nombre":"Almuerzo","horaInicio":11,"horaFin":15}]

# ---------------------------------------------------------------------------
# Agente de sincronizacion outbox/inbox tienda<->nube (F1-T5, arquitectura.md
# §4.4/§6.4). Si CLOUD_SYNC_URL no esta definido, el agente queda deshabilitado
# (loguea un warning al arrancar) y EventoDominio simplemente sigue acumulando
# eventos pendientes sin drenar. No hay nube real todavia (Fase 5): en
# desarrollo se apunta al mock-cloud de test (ver test/mock-cloud/).
# CLOUD_SYNC_URL="https://nube.chickenkitchen.example"

# Tamano de lote por request a POST /sync/eventos (default 50).
# SYNC_BATCH_SIZE=50
# Tope de lotes drenados en un mismo ciclo antes de esperar al proximo tick (default 20).
# SYNC_MAX_LOTES_POR_CICLO=20
# Reintentos con backoff exponencial + jitter antes de rendirse en el ciclo actual (default 4).
# SYNC_MAX_REINTENTOS=4
# Timeout por request HTTP de sync, en ms (default 10000).
# SYNC_TIMEOUT_MS=10000
# Intervalo del ciclo outbox (push a la nube), en ms (default 15000).
# SYNC_INTERVALO_MS=15000
# Intervalo del ciclo inbox (pull de config desde la nube), en ms (default 30000).
# SYNC_INBOX_INTERVALO_MS=30000

# mTLS tienda<->nube (ADR-0005, obligatorio en produccion). Rutas de archivo a
# certificado de cliente, llave privada y CA — NUNCA commitear los archivos
# reales ni pegar su contenido aqui; los provee el gestor de secretos de la
# tienda. Si las 3 faltan, el cliente de sync cae a HTTP/HTTPS simple sin
# certificado de cliente: SOLO aceptable para desarrollo local (ver
# src/sync/mtls-config.ts), nunca para trafico real tienda<->nube.
# MTLS_CERT_PATH="/etc/ckpos/mtls/store-client.crt"
# MTLS_KEY_PATH="/etc/ckpos/mtls/store-client.key"
# MTLS_CA_PATH="/etc/ckpos/mtls/cloud-ca.crt"

# ---------------------------------------------------------------------------
# Impresora ESC/POS + cajon monedero (F2-T4, ADR-0006 F0-T3, arquitectura.md
# §3/§9). Si IMPRESORA_HOST no esta definido, el Store Server usa
# SimuladorImpresoraAdapter (imprime por consola, NO hardware real) — es el
# default para desarrollo/sandbox sin impresora fisica. Definir IMPRESORA_HOST
# activa EscPosImpresoraAdapter (ESC/POS real sobre TCP, RAW port 9100 tipico
# de impresoras termicas de red Epson/Star). Ver src/hardware/README dentro
# del store-server/README.md seccion "Hardware".
# IMPRESORA_HOST="192.168.1.50"
# IMPRESORA_PUERTO=9100

# ---------------------------------------------------------------------------
# Monitoreo de conectividad a internet por tienda (F3-T2, PLAN_DE_PRODUCCION.md
# Fase 3). Senal NUEVA e independiente del agente de sincronizacion (F1-T5):
# verifica alcance de red cada CONECTIVIDAD_INTERVALO_MS (mucho mas rapido que
# SYNC_INTERVALO_MS) para poder alertar ANTES de que el outbox note el corte.
# Ver src/conectividad/ y store-server/README.md.

# Hosts a verificar cada ciclo, separados por coma. Si no se define, usa un
# default de 3 proveedores DISTINTOS (Google/Cloudflare/Microsoft) para no
# depender de un unico punto de fallo al medir "hay internet" (ver
# src/conectividad/conectividad-config.ts).
# CONECTIVIDAD_HOSTS="https://www.google.com/generate_204,https://www.cloudflare.com,https://www.microsoft.com"

# Cadencia del ciclo de verificacion, en ms (default 20000 = 20s).
# CONECTIVIDAD_INTERVALO_MS=20000
# Timeout por host verificado, en ms (default 5000).
# CONECTIVIDAD_TIMEOUT_MS=5000
# Cuantos hosts (de los configurados) deben fallar para pasar a "degradado"
# (no todos, eso ya es "sin_conexion"). Default 1.
# CONECTIVIDAD_MIN_FALLOS_DEGRADADO=1
# Evaluaciones CONSECUTIVAS coincidentes antes de CONFIRMAR un cambio de
# estado (debounce anti-flapping: un unico blip de red no dispara una alerta).
# Default 2.
# CONECTIVIDAD_CONFIRMACIONES_REQUERIDAS=2
# Cuantas transiciones recientes devuelve GET /api/v1/conectividad/estado en
# "historialReciente" (default 20).
# CONECTIVIDAD_HISTORIAL_MAX=20
